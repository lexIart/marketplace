<div class="max-w-7xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Каталог товаров</h1>

  <%# Фильтры %>
  <div class="flex flex-wrap items-center gap-3 mb-8">
    <%# Категории %>
    <div class="flex flex-wrap gap-2">
      <%= link_to 'Все', catalog_products_path(sort: params[:sort]),
            class: "px-3 py-1 rounded-full text-sm border #{params[:category].blank? ? 'bg-gray-900 text-white border-gray-900' : 'border-gray-300 hover:bg-gray-50'}" %>
      <% @categories.each do |category| %>
        <%= link_to category.name, catalog_products_path(category: category.slug, sort: params[:sort]),
              class: "px-3 py-1 rounded-full text-sm border #{params[:category] == category.slug ? 'bg-gray-900 text-white border-gray-900' : 'border-gray-300 hover:bg-gray-50'}" %>
      <% end %>
    </div>

    <%# Сортировка %>
    <div class="ml-auto">
      <%= form_with url: catalog_products_path, method: :get, data: { turbo: false } do |f| %>
        <%= f.hidden_field :category_id, value: params[:category_id] %>
        <%= f.select :sort,
              [['Сначала новые', 'newest'], ['Сначала старые', 'oldest'], ['А–Я', 'name_asc'], ['Я–А', 'name_desc']],
              { selected: params[:sort] || 'newest' },
              { onchange: 'this.form.submit()', class: 'text-sm border border-gray-300 rounded-lg px-3 py-2 bg-white' } %>
      <% end %>
    </div>
  </div>

  <% if @products.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% @products.each do |product| %>
        <% cache product do %>
          <%= link_to catalog_product_path(product), class: "group block bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow border border-gray-100" do %>
            <div class="aspect-square bg-gray-100 rounded-t-xl overflow-hidden">
              <% if product.thumbnail.attached? %>
                <%= image_tag product.thumbnail, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300", alt: product.name %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center text-gray-400 text-sm">Нет фото</div>
              <% end %>
            </div>
            <div class="p-4">
              <h2 class="font-semibold text-gray-900 text-sm leading-tight line-clamp-2"><%= product.name %></h2>
              <% if product.category %>
                <p class="text-xs text-gray-400 mt-1"><%= product.category.name %></p>
              <% end %>
              <p class="text-sm font-medium text-gray-700 mt-2">
                <% min_price = product.variants.map(&:price).min %>
                <% if min_price %>
                  от <%= number_to_currency(min_price, unit: '₽', format: '%n %u', separator: ',', delimiter: ' ') %>
                <% else %>
                  Цена не указана
                <% end %>
              </p>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
    <%# Пагинация %>
    <% if @pagy.pages > 1 %>
      <div class="mt-10 flex justify-center items-center gap-1">
        <% if @pagy.prev %>
          <%= link_to '← Назад', url_for(page: @pagy.prev), class: "px-4 py-2 rounded-lg border border-gray-300 text-sm hover:bg-gray-50" %>
        <% end %>

        <% (1..@pagy.pages).each do |num| %>
          <% if num == @pagy.page %>
            <span class="px-4 py-2 rounded-lg bg-gray-900 text-white text-sm"><%= num %></span>
          <% else %>
            <%= link_to num, url_for(page: num), class: "px-4 py-2 rounded-lg border border-gray-300 text-sm hover:bg-gray-50" %>
          <% end %>
        <% end %>

        <% if @pagy.next %>
          <%= link_to 'Вперёд →', url_for(page: @pagy.next), class: "px-4 py-2 rounded-lg border border-gray-300 text-sm hover:bg-gray-50" %>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p class="text-gray-500 text-center py-20">Товаров пока нет.</p>
  <% end %>
</div>
