<div class="max-w-5xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Корзина</h1>

  <% if @cart_items.any? %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <div class="bg-white rounded-xl border border-gray-200 px-6">
          <%= render partial: "carts/cart_item", collection: @cart_items, as: :cart_item %>
        </div>
      </div>
      <div class="lg:col-span-1">
        <%= render "summary" %>
      </div>
    </div>
  <% else %>
    <div class="text-center py-20">
      <p class="text-gray-400 text-lg mb-4">Корзина пуста</p>
      <%= link_to "Перейти в каталог", catalog_products_path, class: "inline-block bg-gray-900 text-white px-6 py-2 rounded-lg text-sm hover:bg-gray-700" %>
    </div>
  <% end %>
</div>
