<h1><%= @product.name %></h1>

<% if @product.thumbnail.attached? %>
  <%= image_tag @product.thumbnail, style: 'max-width: 400px' %>
<% end %>

<p>Статус: <%= @product.status %></p>
<p>Категория: <%= @product.category&.name || 'Без категории' %></p>

<div><%= @product.description %></div>

<% if @product.specifications.any? %>
  <h2>Характеристики</h2>
  <table>
    <% @product.specifications.each do |key, value| %>
      <tr>
        <td><strong><%= key %></strong></td>
        <td><%= value %></td>
      </tr>
    <% end %>
  </table>
<% end %>

<h2>Варианты (<%= @product.variants.count %>)</h2>

<% if @product.variants.any? %>
  <table>
    <thead>
      <tr>
        <th>SKU</th>
        <th>Цена</th>
        <th>Остаток</th>
        <th>Опции</th>
      </tr>
    </thead>
    <tbody>
      <% @product.variants.each do |variant| %>
        <tr>
          <td><%= variant.sku %></td>
          <td><%= variant.price %></td>
          <td><%= variant.stock %></td>
          <td><%= variant.option_summary %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>Вариантов нет.</p>
  <%= button_to 'Добавить продукт без вариаций',
                add_simple_variant_seller_product_path(@product),
                method: :post,
                data: { turbo_confirm: 'Добавить простой вариант без опций?' } %>
<% end %>

<h2>Сгенерировать варианты</h2>

<%= form_with url: generate_variants_seller_product_path(@product) do |f| %>
  <div>
    <%= f.label :default_price, 'Цена по умолчанию' %>
    <%= f.number_field :default_price, step: 0.01, min: 0 %>
  </div>

  <div>
    <%= f.label :default_stock, 'Остаток по умолчанию' %>
    <%= f.number_field :default_stock, step: 1, min: 0, value: 0 %>
  </div>

  <% OptionType.includes(:option_values).each do |option_type| %>
    <div>
      <strong><%= option_type.presentation %></strong>
      <% option_type.option_values.each do |option_value| %>
        <label>
          <%= check_box_tag "selected_options[#{option_type.id}][]", option_value.id %>
          <%= option_value.presentation %>
        </label>
      <% end %>
    </div>
  <% end %>

  <%= f.submit 'Сгенерировать' %>
<% end %>

<%= link_to 'Редактировать', edit_seller_product_path(@product) %>
<%= link_to 'Назад', seller_products_path %>
